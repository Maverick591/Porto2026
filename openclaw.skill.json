{
  "name": "Porto2026",
  "version": "1.2.0",
  "description": "Controle financeiro da viagem EHS Porto 2026 com entrada por texto, fotos/prints e áudio, auth por API key, dashboard e exportação CSV.",
  "entrypoint": "porto2026.api:app",
  "runtime": "python",
  "commands": [
    {
      "name": "registrar_despesa_texto",
      "endpoint": "/expense/text",
      "method": "POST",
      "description": "Registra despesa por texto livre."
    },
    {
      "name": "registrar_despesa_foto",
      "endpoint": "/expense/photo",
      "method": "POST",
      "description": "Registra despesa por foto ou print de comprovante."
    },
    {
      "name": "registrar_despesa_audio",
      "endpoint": "/expense/audio",
      "method": "POST",
      "description": "Registra despesa por áudio."
    },
    {
      "name": "consultar_resumo",
      "endpoint": "/summary",
      "method": "GET",
      "description": "Consulta resumo financeiro atualizado."
    },
    {
      "name": "consultar_despesas",
      "endpoint": "/expenses",
      "method": "GET",
      "description": "Lista as despesas mais recentes."
    },
    {
      "name": "atualizar_despesa",
      "endpoint": "/expense/{expense_id}",
      "method": "PATCH",
      "description": "Corrige manualmente uma despesa."
    },
    {
      "name": "excluir_despesa",
      "endpoint": "/expense/{expense_id}",
      "method": "DELETE",
      "description": "Exclui uma despesa."
    },
    {
      "name": "exportar_csv",
      "endpoint": "/export/csv",
      "method": "GET",
      "description": "Exporta todas as despesas em CSV."
    },
    {
      "name": "abrir_dashboard",
      "endpoint": "/dashboard",
      "method": "GET",
      "description": "Abre o dashboard web simples."
    }
  ]
}
