{
  "name": "Porto2026",
  "version": "1.1.0",
  "description": "Controle financeiro da viagem EHS Porto 2026 com entrada por texto, fotos/prints e áudio.",
  "entrypoint": "porto2026.api:app",
  "runtime": "python",
  "commands": [
    {
      "name": "registrar_despesa_texto",
      "endpoint": "/expense/text",
      "method": "POST",
      "description": "Registra despesa por texto livre."
    },
    {
      "name": "registrar_despesa_foto",
      "endpoint": "/expense/photo",
      "method": "POST",
      "description": "Registra despesa por foto ou print de comprovante."
    },
    {
      "name": "registrar_despesa_audio",
      "endpoint": "/expense/audio",
      "method": "POST",
      "description": "Registra despesa por áudio."
    },
    {
      "name": "consultar_resumo",
      "endpoint": "/summary",
      "method": "GET",
      "description": "Consulta resumo financeiro atualizado."
    }
  ]
}
